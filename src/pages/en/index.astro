---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Header from "../../components/Header.astro";
import Hero from "../../components/Hero.astro";
import ProofStrip from "../../components/ProofStrip.astro";
import Offer from "../../components/Offer.astro";
import References from "../../components/References.astro";
import Visibility from "../../components/Visibility.astro";
import Process from "../../components/Process.astro";
import Studio from "../../components/Studio.astro";
import Contact from "../../components/Contact.astro";
import Footer from "../../components/Footer.astro";
import { content } from "../../content/site";
const t = content.en;
---
<BaseLayout title={t.meta.title} description={t.meta.description} lang="en" canonicalPath="/en/">
  <Header lang="en" nav={t.nav} cta={t.cta} />
  <main><Hero {...t.hero} cta={t.cta} secondaryCta={t.secondaryCta} /><ProofStrip {...t.proof} /><Offer {...t.offer} /><References {...t.references} /><Visibility {...t.visibility} /><Process {...t.process} /><Studio {...t.studio} /><Contact {...t.contact} /></main>
  <Footer {...t.footer} />
</BaseLayout>
